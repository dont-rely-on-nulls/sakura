#!/usr/bin/env bash
set -e
if [[ ! -d "/Users/mmagueta/Developer/Nekoma/sakura-ocaml" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/Users/mmagueta/Developer/Nekoma/sakura-ocaml")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/Users/mmagueta/Developer/Nekoma/sakura-ocaml" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/Users/mmagueta/Developer/Nekoma/sakura-ocaml/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/Users/mmagueta/Developer/Nekoma/sakura-ocaml/.envrc" "/Users/mmagueta/Developer/Nekoma/sakura-ocaml/.direnv"/*.rc
